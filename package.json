{
  "name": "aegis-arena",
  "version": "1.0.0",
  "description": "AI-versus-AI strategy game on AEGIS Engine + Uniswap v4 on X Layer",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:contracts": "forge build",
    "test": "vitest run",
    "test:game": "vitest run tests/integration/full-game-flow.test.ts",
    "test:contracts": "forge test",
    "dev": "node --loader ts-node/esm src/server/index.ts",
    "deploy": "bash deploy/deployment-guide.sh",
    "twap:seed": "bash deploy/twap-warmup.sh"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "express": "^4.18.0",
    "@types/express": "^4.17.17"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "vitest": "^1.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0"
  }
}
