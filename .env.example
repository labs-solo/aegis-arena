# ================================================================
# Hackathon Primary Market (OKB/USD₮0 Pool on X Layer)
# ================================================================
HACKATHON_POOL_ID=0xd5a401023b6ee3ae340bfadb90758385dc9d2463a20dc24e43e913bc7f209cf4
HACKATHON_TOKEN0=0x0000000000000000000000000000000000000000
HACKATHON_TOKEN1=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
HACKATHON_HOOK=0xc54aC33a60BeED0c10C32D8E4434166AF68550cc

# ================================================================
# x402 Payment Gateway
# ================================================================
X402_GATEWAY_URL=https://x402.example.com
X402_API_KEY=

# ================================================================
# Server Configuration
# ================================================================
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# ================================================================
# Logging Level
# ================================================================
LOG_LEVEL=info

# ================================================================
# Optional: Tenderly for simulation/debugging
# ================================================================
TENDERLY_USER=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=

# ================================================================
# OKX Onchain Gateway (for TX simulation + optimized broadcast)
# ================================================================
OKX_GATEWAY_API_KEY=
OKX_GATEWAY_API_SECRET=
OKX_GATEWAY_PASSPHRASE=
OKX_GATEWAY_BASE_URL=https://www.okx.com

# ================================================================
# OKX Market API (optional; public API doesn't require key)
# ================================================================
# Leave blank to use public endpoints without authentication
OKX_MARKET_API_KEY=

# Market data instrument ID for TrendFollower trend detection
# Must match a valid OKX instrument (e.g., OKB-USDT, OKB-USDC)
# Note: WOKB on X Layer maps to OKB on OKX
OKX_MARKET_INSTRUMENT_ID=OKB-USDT
