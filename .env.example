# aegis-arena .env.example
# Required: set all values before running

# Network RPC endpoint
RPC_URL=https://testrpc.xlayer.tech

# Relayer signer private key (orchestrator wallet — must be authorized in Arena.sol)
# Run Arena.setRelayer(this_wallet_address, true) before first executeBatch() call
PRIVATE_KEY=0x...

# Contract addresses
ARENA_ADDRESS=0x...
BOUNTY_ADDRESS=0x...

# Pool address (WOKB/USD₮0 on X Layer)
POOL_ADDRESS=0x...

# Agent addresses (must be registered in Arena.sol for each round)
AGENT_PASSIVE_LP_ADDRESS=0x...
AGENT_TREND_FOLLOWER_ADDRESS=0x...
AGENT_PREDATOR_ADDRESS=0x...

# Optional
GATEWAY_URL=https://www.okx.com/web3/build/dev-tools/pre-execution
PORT=3000
NODE_ENV=development

# OKX Market API (TrendFollower trend detection)
OKX_MARKET_API_KEY=
OKX_MARKET_INSTRUMENT_ID=OKB-USDT
