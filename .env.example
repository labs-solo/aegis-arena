# X Layer RPC Configuration
X_LAYER_RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196

# Agent Private Keys (must have USDC + WOKB for initial entry)
# Generate new keypairs or import existing:
# cast wallet new
AGENT_PASSIVE_LP_PRIVATE_KEY=
AGENT_TREND_FOLLOWER_PRIVATE_KEY=
AGENT_PREDATOR_PRIVATE_KEY=

# Game Orchestrator Private Key (for Arena admin actions)
ORCHESTRATOR_PRIVATE_KEY=

# AEGIS Engine PositionManager Address
# CRITICAL: Must match aegis-engine PR #18 deployment on X Layer
# Instructions: See docs/guides/POSITION_MANAGER_LOOKUP.md
AEGIS_POSITION_MANAGER=

# Arena.sol Deployment Address
# Set after running: npm run deploy
ARENA_ADDRESS=

# x402 Payment Gateway
X402_GATEWAY_URL=https://x402.example.com
X402_API_KEY=

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# Logging Level
LOG_LEVEL=info

# Optional: Tenderly for simulation/debugging
TENDERLY_USER=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=
